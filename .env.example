# ============================================
# Maxillofacialis Rehabilitáció - Environment Variables Template
# ============================================
# Másold ezt a fájlt .env.local néven és töltsd ki a saját értékeiddel!
# cp .env.example .env.local
# ============================================

# ============================================
# Admin Login Credentials
# ============================================
# Az admin bejelentkezési adatok a login oldalhoz
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_ADMIN_PASSWORD=changeme

# ============================================
# Database Connection
# ============================================
# PostgreSQL adatbázis kapcsolati string
# Formátum: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME

# Helyi fejlesztéshez (ha lokális PostgreSQL-t használsz):
DATABASE_URL=postgresql://postgres:password@localhost:5432/maxillofacial_rehab

# Távoli adatbázis esetén:
# DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME

# Cloud adatbázis esetén (Render, AWS RDS, stb.) adj hozzá SSL-t:
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ============================================
# Environment
# ============================================
# Állítsd be 'production'-re production környezetben
NODE_ENV=development

# ============================================
# Admin email értesítések (web app)
# ============================================
# Batch összefoglaló: a cron (scripts/cron-sync.js) Europe/Budapest 6, 9, 12, 14, 18 órában hívja az API-t.
# Alapból azonnali email: register, patient_created, patient_portal_registered, new_appointment_request, password_reset_requested.
# ADMIN_NOTIFICATION_IMMEDIATE=true → minden típus azonnali (nincs batch, csak ami nem sikerült küldeni).
# ADMIN_NOTIFICATION_IMMEDIATE_EXTRA=login,message_sent → extra típusok azonnali listához (vesszővel)

# ============================================
# Episode plan migration (default off)
# ============================================
# READ_PLAN_ITEMS=on — treatment-plan timeline uses episode_plan_items + plan-linked appointments
# WRITE_PLAN_ITEMS=on — plan-item write authority + POST /api/admin/treatment-plan-json-quarantine ingest
# SCHEDULER_USE_PLAN_ITEMS=on — reserved post scheduler drain (Phase 6a)
# READ_PLAN_ITEMS=off
# WRITE_PLAN_ITEMS=off
# SCHEDULER_USE_PLAN_ITEMS=off

# ============================================
# Megjegyzések
# ============================================
# - A .env.local fájl NEM kerül a Git repository-ba
# - Production környezetben használj környezeti változókat (Render, Vercel, stb.)
# - Mindig használj erős jelszavakat production környezetben!
